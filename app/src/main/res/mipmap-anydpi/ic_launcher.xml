<?xml version="1.0" encoding="utf-8"?>
<!-- Fallback launcher icon for API 23–25 (no adaptive-icon support).
     API 26+ uses mipmap-anydpi-v26/ic_launcher.xml (adaptive-icon). -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <color android:color="#1565C0" />
    </item>
    <item
        android:top="16dp"
        android:bottom="16dp"
        android:left="16dp"
        android:right="16dp"
        android:drawable="@drawable/ic_radio" />
</layer-list>
